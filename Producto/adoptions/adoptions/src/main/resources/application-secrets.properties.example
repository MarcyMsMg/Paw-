# Copy this file as application-secrets.properties and keep it out of git.
# JWT_SECRET must match users: pawplus.security.jwt-secret.
paw.security.jwt-secret=${JWT_SECRET}

# INTERNAL_API_KEY must match users: pawplus.internal-api-key.
paw.services.users.internal-api-key=${INTERNAL_API_KEY}

# Optional local database override.
# spring.datasource.password=${SUPABASE_DB_PASSWORD}