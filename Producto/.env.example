# Puertos locales
API_GATEWAY_PORT=8080
USERS_PORT=8081
CAMPAIGNS_PORT=8082
DONATIONS_PORT=8083
ADOPTIONS_PORT=8084
FEED_PORT=8085
NOTIFICATIONS_PORT=8086
FRONTEND_PORT=5173

# Seguridad
JWT_SECRET=replace-with-at-least-32-bytes
INTERNAL_API_KEY=replace-with-internal-api-key
JWT_EXPIRATION_MINUTES=120
PAWPLUS_ADMIN_EMAIL=admin@pawplus.cl
PAWPLUS_ADMIN_PASSWORD=replace-with-admin-password

# CORS
GATEWAY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Datasources Supabase/PostgreSQL por servicio
USERS_DATASOURCE_URL=jdbc:postgresql://host:5432/database
USERS_DATASOURCE_USERNAME=postgres
USERS_DATASOURCE_PASSWORD=replace-with-password

CAMPAIGNS_DATASOURCE_URL=jdbc:postgresql://host:5432/database
CAMPAIGNS_DATASOURCE_USERNAME=postgres
CAMPAIGNS_DATASOURCE_PASSWORD=replace-with-password

DONATIONS_DATASOURCE_URL=jdbc:postgresql://host:5432/database
DONATIONS_DATASOURCE_USERNAME=postgres
DONATIONS_DATASOURCE_PASSWORD=replace-with-password

ADOPTIONS_DATASOURCE_URL=jdbc:postgresql://host:5432/database
ADOPTIONS_DATASOURCE_USERNAME=postgres
ADOPTIONS_DATASOURCE_PASSWORD=replace-with-password

FEED_DATASOURCE_URL=jdbc:postgresql://host:5432/database
FEED_DATASOURCE_USERNAME=postgres
FEED_DATASOURCE_PASSWORD=replace-with-password

NOTIFICATIONS_DATASOURCE_URL=jdbc:postgresql://host:5432/database
NOTIFICATIONS_DATASOURCE_USERNAME=postgres
NOTIFICATIONS_DATASOURCE_PASSWORD=replace-with-password

# Mercado Pago
MERCADOPAGO_ACCESS_TOKEN=replace-with-token
MERCADOPAGO_WEBHOOK_SECRET=replace-with-webhook-secret
MERCADOPAGO_NOTIFICATION_URL=https://your-public-api.example.com/api/donations/webhook
MERCADOPAGO_BACK_URL_SUCCESS=http://localhost:5173/persona/mis-donaciones
MERCADOPAGO_BACK_URL_FAILURE=http://localhost:5173/crowdfundings
MERCADOPAGO_BACK_URL_PENDING=http://localhost:5173/persona/mis-donaciones
MERCADOPAGO_CURRENCY=CLP

# Frontend
VITE_API_BASE_URL=http://localhost:8080/api